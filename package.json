{
  "name": "saas-core",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "play": "pnpm --filter @saas-core/playground dev",
    "planner:dev": "pnpm --filter @saas-core/planner dev",
    "planner:build": "pnpm --filter @saas-core/planner build",
    "planner:lint": "pnpm --filter @saas-core/planner lint",
    "planner:typecheck": "pnpm --filter @saas-core/planner typecheck",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:play": "turbo run test --filter=playground",
    "test:ui": "turbo run test --filter=@saas-core/core-ui",
    "test:core": "turbo run test --filter=@saas-core/core",
    "check-all": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "fix-all": "pnpm run format && pnpm run lint:fix && pnpm run check-all"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.9.6"
  }
}
